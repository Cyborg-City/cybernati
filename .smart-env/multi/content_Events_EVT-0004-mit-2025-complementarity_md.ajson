ered about photons. Confirmed Bohr's complementarity principle — any path information gathered causes the interference pattern to vanish. Directly disproved Einstein's 1927 hypothesis.","related":["[[PER-0004-niels-bohr]]","[[PER-0003-albert-einstein]]"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:content/Events/EVT-0004-mit-2025-complementarity.md#---frontmatter---": {"path":null,"last_embed":{"hash":"1re27ye","at":1778850379607},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02515189,0.00687411,-0.04596096,-0.02131135,-0.01431509,0.02281274,0.05985545,0.0233613,-0.01835779,-0.01904774,0.06591071,-0.05412818,-0.02399059,0.01514933,0.04283182,0.00240296,-0.02143504,-0.04443623,-0.08241373,0.02663969,0.09779325,-0.07505141,0.01402153,-0.09281228,0.05525585,0.07522769,0.02106638,-0.08132243,-0.00924905,-0.22295837,0.0222741,-0.01774823,-0.02370553,-0.00121991,0.05779478,-0.02718824,-0.06382211,0.00856895,-0.02288559,0.00864512,0.01176783,-0.00609268,0.01769425,0.00806276,0.00123811,-0.0168735,-0.01061319,0.02433621,-0.07427683,-0.00357578,-0.0303448,-0.00195974,-0.0028934,-0.00512111,0.03240267,0.05082038,0.00815308,0.02078837,0.00312437,0.07647207,0.02561657,0.04326235,-0.17724694,0.05355242,0.0939403,0.00214294,-0.02379264,-0.12845995,0.07971359,0.00800597,-0.07189723,0.02123119,-0.0338382,0.03046265,0.04714789,-0.02938413,0.01318888,-0.08358588,-0.05762059,0.01348422,0.00028679,-0.05712862,-0.01234139,-0.01967808,-0.02520478,0.01649043,0.02005755,-0.00563646,0.02219514,0.00881074,-0.01405404,-0.06881074,0.01814923,0.02939293,-0.00372908,0.04817015,0.07265027,0.04893636,0.04844949,0.09506065,-0.04782729,0.0843145,-0.04640406,0.01592886,0.03373495,-0.02072728,-0.06900337,-0.03895129,0.00082602,0.00095802,0.07472536,-0.02827923,0.06367923,-0.02838241,0.04858323,0.05882477,0.10466643,-0.00270626,-0.01562239,0.00913855,-0.00524166,0.04027504,0.06366724,-0.01470613,-0.06361359,0.00749254,-0.01062288,0.06018367,-0.02940051,0.00177349,0.05394626,-0.0